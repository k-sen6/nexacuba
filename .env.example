# NexaCuba - Variables de Entorno
# Copia este archivo a .env.local y completa los valores

# Supabase - Crear proyecto en https://supabase.com/dashboard
# 1. Crea un nuevo proyecto
# 2. Ve a Project Settings > API
# 3. Copia la URL y la Anon Key
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Después de conectar Supabase:
# 1. Ejecuta supabase-schema.sql en SQL Editor
# 2. Ejecuta seed.sql para insertar categorías
# 3. Regístrate como usuario, luego haz:
#    UPDATE perfiles SET rol = 'admin' WHERE email = 'tu-email';
